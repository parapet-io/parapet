<?xml version="1.0" encoding="UTF-8"?>
<!--
  Console stays at WARN so `sbt test` output is not drowned in scheduler debug lines.

  The FILE appender rotates at 100MB per file and caps total on-disk history at 500MB
  (rolled files are gzipped). This is important for overnight stress runs: at DEBUG
  level the scheduler emits a line per envelope hop and an unbounded FileAppender
  would fill the disk in a few hours. With the rolling policy the worst case is:
    scheduler-test.log            (active, <= 100MB)
    scheduler-test.<date>.1.log.gz
    scheduler-test.<date>.2.log.gz
    ...                           (total compressed history capped at 500MB)

  Overnight runs are expected to `tail -f target/scheduler-test.log` for live
  monitoring; that file always contains the most recent slice.
-->
<configuration>
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="file" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>target/scheduler-test.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>target/scheduler-test.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <totalSizeCap>500MB</totalSizeCap>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
      Scheduler logs are only emitted when `ParConfig.devMode = true`; the stress harness enables it.
      Route them to the file at DEBUG so each envelope hop leaves a trace.
    -->
    <logger name="io.parapet.core.Scheduler" level="DEBUG" additivity="false">
        <appender-ref ref="file"/>
    </logger>
    <logger name="parapet-scheduler" level="DEBUG" additivity="false">
        <appender-ref ref="file"/>
    </logger>
    <logger name="io.parapet.tests.intg" level="INFO" additivity="false">
        <appender-ref ref="file"/>
        <appender-ref ref="console"/>
    </logger>

    <root level="warn">
        <appender-ref ref="console"/>
    </root>
</configuration>
